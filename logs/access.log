2026-06-18T14:39:43.601Z GET /chat/history?session_id=6b0d43b4-a87b-445d-8600-d567dd5d7998 200 - 139.880 ms resBody={"data":[{"_id":"6a33fce2b6472906c5fdb82f","id":"755c612d-4a41-46d7-bd25-e83801eb08a7","user_message":"–Я—А–Њ—Б–Љ—В—А–Є –±–і","ai_response":"–С–∞–Ј–∞ –і–∞–љ–љ—Л—Е –њ—Г—Б—В–∞—П –Є–ї–Є –љ–µ –њ–Њ–і–Ї–ї—О—З–µ–љ–∞. –Ъ–∞–Ї–Є–µ –і–∞–љ–љ—Л–µ –≤—Л —Е–Њ—В–Є—В–µ –њ—А–Њ—Б–Љ–Њ—В—А–µ—В—М?","created_at":"2026-06-18T14:12:50.781Z"},{"_id":"6a33fcf8b6472906c5fdb830","id":"767ceb66-4e9f-4f73-b2c6-fec0bb79ff85","user_message":"–Ґ—Л –Љ–Њ–ґ–µ—И—М –њ–Њ–і–Ї–ї—О—З–Є—В—М—Б—П –Ї –±–і –Є –њ—А–Њ—Б–Љ–∞—В—А–Є–≤–∞—В—М –і–∞–љ–љ—Л–µ?","ai_response":"–Э–µ—В, —Г –Љ–µ–љ—П –љ–µ—В –њ—А—П–Љ–Њ–≥–Њ –і–Њ—Б—В—Г–њ–∞ –Ї –±–∞–Ј–µ –і–∞–љ–љ—Л—Е. –ѓ –Љ–Њ–≥—Г —В–Њ–ї—М–Ї–Њ –Њ–±—А–∞–±–∞—В—Л–≤–∞—В—М —В–µ–Ї—Б—В–Њ–≤—Л–µ –Ј–∞–њ—А–Њ—Б—Л –Є –њ—А–µ–і–Њ—Б—В–∞–≤–ї—П—В—М –Њ–±—Й—Г—О –Є–љ—Д–Њ—А–Љ–∞—Ж–Є—О. –Ф–ї—П –њ–Њ–і–Ї–ї—О—З–µ–љ–Є—П –Ї –±–∞–Ј–µ –і–∞–љ–љ—Л—Е –љ–µ–Њ–±—Е–Њ–і–Є–Љ—Л –Ї–Њ–љ–Ї—А–µ—В–љ—Л–µ —А–∞–Ј—А–µ—И–µ–љ–Є—П –Є –љ–∞—Б—В—А–Њ–є–Ї–Є.","created_at":"2026-06-18T14:13:12.367Z"},{"_id":"6a340252d9b5fcdbe6acd4b2","id":"fc07a7a7-ffd6-443f-85a3-28dd7507de31","user_message":"–Ї–∞–Ї–∞—П –њ–Њ–≥–Њ–і–∞ –≤ –∞—Б—В–∞–љ–µ","ai_response":"–ѓ –љ–µ –Љ–Њ–≥—Г –њ—А–µ–і–Њ—Б—В–∞–≤–Є—В—М —В–µ–Ї—Г—Й—Г—О –њ–Њ–≥–Њ–і—Г –≤ —А–µ–ґ–Є–Љ–µ —А–µ–∞–ї—М–љ–Њ–≥–Њ –≤—А–µ–Љ–µ–љ–Є. –Ю–і–љ–∞–Ї–Њ —П –Љ–Њ–≥—Г –њ—А–µ–і–ї–Њ–ґ–Є—В—М –≤–∞–Љ –њ—А–Њ–≤–µ—А–Є—В—М –њ—А–Њ–≥–љ–Њ–Ј –њ–Њ–≥–Њ–і—Л –љ–∞ —Б–∞–є—В–µ —Б–µ—А–≤–Є—Б–∞ –њ–Њ–≥–Њ–і—Л, —В–∞–Ї–Њ–≥–Њ –Ї–∞–Ї –ѓ–љ–і–µ–Ї—Б.–Я–Њ–≥–Њ–і–∞ –Є–ї–Є AccuWeather, –і–ї—П –њ–Њ–ї—Г—З–µ–љ–Є—П –∞–Ї—В—Г–∞–ї—М–љ–Њ–є –Є–љ—Д–Њ—А–Љ–∞—Ж–Є–Є –Њ –њ–Њ–≥–Њ–і–µ –≤ –Р—Б—В–∞–љ–µ.","created_at":"2026-06-18T14:36:02.124Z"},{"_id":"6a340269d9b5fcdbe6acd4b3","id":"e80dfec0-a272-436e-a941-19ed73c97384","user_message":"–Ї–∞–Ї–Њ–µ –≤—А–µ–Љ—П –≤ –∞—Б—В–∞–љ–µ","ai_response":"–Т –Р—Б—В–∞–љ–µ –≤—А–µ–Љ—П —Б–Њ–Њ—В–≤–µ—В—Б—В–≤—Г–µ—В –≤—А–µ–Љ–µ–љ–Є –≤ –Ј–Њ–љ–µ UTC+6 (–Р–ї–Љ–∞—В–Є–љ—Б–Ї–Њ–µ –≤—А–µ–Љ—П). –Х—Б–ї–Є –≤—Л —Е–Њ—В–Є—В–µ —Г–Ј–љ–∞—В—М —В–µ–Ї—Г—Й–µ–µ –≤—А–µ–Љ—П –≤ –Р—Б—В–∞–љ–µ, —П –Љ–Њ–≥—Г –њ—А–µ–і–ї–Њ–ґ–Є—В—М –≤–∞–Љ –њ—А–Њ–≤–µ—А–Є—В—М –µ–≥–Њ –љ–∞ —Б–∞–є—В–µ –Љ–Є—А–Њ–≤–Њ–≥–Њ –≤—А–µ–Љ–µ–љ–Є –Є–ї–Є –љ–∞ –≤–∞—И–µ–Љ —В–µ–ї–µ—Д–Њ–љ–µ/–Ї–Њ–Љ–њ—М—О—В–µ—А–µ.","created_at":"2026-06-18T14:36:25.763Z"}]}
2026-06-18T14:39:51.724Z POST /chat 200 981 2344.574 ms resBody={"answer":"–ѓ –љ–µ –Љ–Њ–≥—Г –њ—А–µ–і–Њ—Б—В–∞–≤–Є—В—М —В–µ–Ї—Г—Й—Г—О –њ–Њ–≥–Њ–і—Г –≤ —А–µ–ґ–Є–Љ–µ —А–µ–∞–ї—М–љ–Њ–≥–Њ –≤—А–µ–Љ–µ–љ–Є. –Ю–і–љ–∞–Ї–Њ —П –Љ–Њ–≥—Г –њ—А–µ–і–ї–Њ–ґ–Є—В—М –≤–∞–Љ –њ—А–Њ–≤–µ—А–Є—В—М –њ—А–Њ–≥–љ–Њ–Ј –њ–Њ–≥–Њ–і—Л –љ–∞ —Б–∞–є—В–µ —Б–µ—А–≤–Є—Б–∞ –њ–Њ–≥–Њ–і—Л, —В–∞–Ї–Њ–≥–Њ –Ї–∞–Ї –ѓ–љ–і–µ–Ї—Б.–Я–Њ–≥–Њ–і–∞ –Є–ї–Є AccuWeather, –і–ї—П –њ–Њ–ї—Г—З–µ–љ–Є—П –∞–Ї—В—Г–∞–ї—М–љ–Њ–є –Є–љ—Д–Њ—А–Љ–∞—Ж–Є–Є –Њ –њ–Њ–≥–Њ–і–µ –≤ –Р—Б—В–∞–љ–µ.\n\n–Э–Њ –µ—Б–ї–Є –≤—Л —Е–Њ—В–Є—В–µ, —П –Љ–Њ–≥—Г –њ—А–µ–і–ї–Њ–ґ–Є—В—М –≤–∞–Љ –љ–µ—Б–Ї–Њ–ї—М–Ї–Њ –≤–∞—А–Є–∞–љ—В–Њ–≤, –≥–і–µ –Љ–Њ–ґ–љ–Њ –љ–∞–є—В–Є –Є–љ—Д–Њ—А–Љ–∞—Ж–Є—О –Њ –њ–Њ–≥–Њ–і–µ –≤ –Р—Б—В–∞–љ–µ:\n\n* –ѓ–љ–і–µ–Ї—Б.–Я–Њ–≥–Њ–і–∞\n* AccuWeather\n* –У–Є–і—А–Њ–Љ–µ—В—Ж–µ–љ—В—А –Ъ–∞–Ј–∞—Е—Б—В–∞–љ–∞\n* –Я–Њ–≥–Њ–і–∞ –љ–∞ —Б–∞–є—В–µ –Ъ–∞–Ј–Є–љ—Д–Њ—А–Љ–∞\n\n–Я–Њ–ґ–∞–ї—Г–є—Б—В–∞, –≤—Л–±–µ—А–Є—В–µ –Њ–і–Є–љ –Є–Ј —Н—В–Є—Е –≤–∞—А–Є–∞–љ—В–Њ–≤, —З—В–Њ–±—Л –њ–Њ–ї—Г—З–Є—В—М –∞–Ї—В—Г–∞–ї—М–љ—Г—О –Є–љ—Д–Њ—А–Љ–∞—Ж–Є—О –Њ –њ–Њ–≥–Њ–і–µ –≤ –Р—Б—В–∞–љ–µ."}
