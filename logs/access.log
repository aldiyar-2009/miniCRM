2026-06-18T14:45:01.339Z GET /chat/history?session_id=0a59d91b-428c-4531-a9b7-ffffdcd12767 304 - 228.063 ms resBody={"data":[{"_id":"6a33f8f830009a8e6422178c","id":"fb35ae65-ef31-4a52-a534-26894518c291","user_message":"–Ї–∞–Ї–∞—П –њ–Њ–≥–Њ–і–∞ –≤ –∞—Б—В–∞–љ–µ —Й–∞—Б","ai_response":"–Ь–љ–µ –љ–µ –і–Њ—Б—В—Г–њ–љ–∞ –∞–Ї—В—Г–∞–ї—М–љ–∞—П –Є–љ—Д–Њ—А–Љ–∞—Ж–Є—П –Њ –њ–Њ–≥–Њ–і–µ –≤ —А–µ–∞–ї—М–љ–Њ–Љ –≤—А–µ–Љ–µ–љ–Є. –†–µ–Ї–Њ–Љ–µ–љ–і—Г—О –њ—А–Њ–≤–µ—А–Є—В—М —В–µ–Ї—Г—Й—Г—О –њ–Њ–≥–Њ–і—Г –≤ –Р—Б—В–∞–љ–µ –љ–∞ —Б–∞–є—В–µ —Б–µ—А–≤–Є—Б–∞ –њ–Њ–≥–Њ–і—Л, –љ–∞–њ—А–Є–Љ–µ—А, –љ–∞ —Б–∞–є—В–µ –ѓ–љ–і–µ–Ї—Б.–Я–Њ–≥–Њ–і–∞ –Є–ї–Є –У–Є–і—А–Њ–Љ–µ—В—Ж–µ–љ—В—А.","created_at":"2026-06-18T13:56:08.582Z"},{"_id":"6a3403cdccdff796e6cfee99","id":"ce0bbb58-1f91-4b4a-a800-dca3660b0c63","user_message":"–Ї–∞–Ї–∞—П –њ–Њ–≥–Њ–і–∞ –≤ –∞—Б—В–∞–љ–µ","ai_response":"–ѓ –љ–µ –Є–Љ–µ—О –і–Њ—Б—В—Г–њ–∞ –Ї –∞–Ї—В—Г–∞–ї—М–љ–Њ–є –Є–љ—Д–Њ—А–Љ–∞—Ж–Є–Є –Њ –њ–Њ–≥–Њ–і–µ –≤ —А–µ–∞–ї—М–љ–Њ–Љ –≤—А–µ–Љ–µ–љ–Є. –Ю–і–љ–∞–Ї–Њ —П –Љ–Њ–≥—Г –њ—А–µ–і–ї–Њ–ґ–Є—В—М –≤–∞–Љ –њ—А–Њ–≤–µ—А–Є—В—М —В–µ–Ї—Г—Й—Г—О –њ–Њ–≥–Њ–і—Г –≤ –Р—Б—В–∞–љ–µ –љ–∞ –Њ–і–љ–Њ–Љ –Є–Ј —Б–ї–µ–і—Г—О—Й–Є—Е —Б–∞–є—В–Њ–≤:\n\n* –ѓ–љ–і–µ–Ї—Б.–Я–Њ–≥–Њ–і–∞\n* –У–Є–і—А–Њ–Љ–µ—В—Ж–µ–љ—В—А\n* AccuWeather\n* Weather.com\n\n–Т–∞–Љ —В–∞–Ї–ґ–µ –Љ–Њ–ґ–љ–Њ –Є—Б–њ–Њ–ї—М–Ј–Њ–≤–∞—В—М –≥–Њ–ї–Њ—Б–Њ–≤—Л–µ –њ–Њ–Љ–Њ—Й–љ–Є–Ї–Є, —В–∞–Ї–Є–µ –Ї–∞–Ї Siri, Google Assistant –Є–ї–Є Alexa, —З—В–Њ–±—Л —Г–Ј–љ–∞—В—М —В–µ–Ї—Г—Й—Г—О –њ–Њ–≥–Њ–і—Г –≤ –Р—Б—В–∞–љ–µ.","created_at":"2026-06-18T14:42:21.200Z"}]}
2026-06-18T14:45:04.942Z GET /chat/history?session_id=6b0d43b4-a87b-445d-8600-d567dd5d7998 304 - 138.347 ms resBody={"data":[{"_id":"6a33fce2b6472906c5fdb82f","id":"755c612d-4a41-46d7-bd25-e83801eb08a7","user_message":"–Я—А–Њ—Б–Љ—В—А–Є –±–і","ai_response":"–С–∞–Ј–∞ –і–∞–љ–љ—Л—Е –њ—Г—Б—В–∞—П –Є–ї–Є –љ–µ –њ–Њ–і–Ї–ї—О—З–µ–љ–∞. –Ъ–∞–Ї–Є–µ –і–∞–љ–љ—Л–µ –≤—Л —Е–Њ—В–Є—В–µ –њ—А–Њ—Б–Љ–Њ—В—А–µ—В—М?","created_at":"2026-06-18T14:12:50.781Z"},{"_id":"6a33fcf8b6472906c5fdb830","id":"767ceb66-4e9f-4f73-b2c6-fec0bb79ff85","user_message":"–Ґ—Л –Љ–Њ–ґ–µ—И—М –њ–Њ–і–Ї–ї—О—З–Є—В—М—Б—П –Ї –±–і –Є –њ—А–Њ—Б–Љ–∞—В—А–Є–≤–∞—В—М –і–∞–љ–љ—Л–µ?","ai_response":"–Э–µ—В, —Г –Љ–µ–љ—П –љ–µ—В –њ—А—П–Љ–Њ–≥–Њ –і–Њ—Б—В—Г–њ–∞ –Ї –±–∞–Ј–µ –і–∞–љ–љ—Л—Е. –ѓ –Љ–Њ–≥—Г —В–Њ–ї—М–Ї–Њ –Њ–±—А–∞–±–∞—В—Л–≤–∞—В—М —В–µ–Ї—Б—В–Њ–≤—Л–µ –Ј–∞–њ—А–Њ—Б—Л –Є –њ—А–µ–і–Њ—Б—В–∞–≤–ї—П—В—М –Њ–±—Й—Г—О –Є–љ—Д–Њ—А–Љ–∞—Ж–Є—О. –Ф–ї—П –њ–Њ–і–Ї–ї—О—З–µ–љ–Є—П –Ї –±–∞–Ј–µ –і–∞–љ–љ—Л—Е –љ–µ–Њ–±—Е–Њ–і–Є–Љ—Л –Ї–Њ–љ–Ї—А–µ—В–љ—Л–µ —А–∞–Ј—А–µ—И–µ–љ–Є—П –Є –љ–∞—Б—В—А–Њ–є–Ї–Є.","created_at":"2026-06-18T14:13:12.367Z"},{"_id":"6a340252d9b5fcdbe6acd4b2","id":"fc07a7a7-ffd6-443f-85a3-28dd7507de31","user_message":"–Ї–∞–Ї–∞—П –њ–Њ–≥–Њ–і–∞ –≤ –∞—Б—В–∞–љ–µ","ai_response":"–ѓ –љ–µ –Љ–Њ–≥—Г –њ—А–µ–і–Њ—Б—В–∞–≤–Є—В—М —В–µ–Ї—Г—Й—Г—О –њ–Њ–≥–Њ–і—Г –≤ —А–µ–ґ–Є–Љ–µ —А–µ–∞–ї—М–љ–Њ–≥–Њ –≤—А–µ–Љ–µ–љ–Є. –Ю–і–љ–∞–Ї–Њ —П –Љ–Њ–≥—Г –њ—А–µ–і–ї–Њ–ґ–Є—В—М –≤–∞–Љ –њ—А–Њ–≤–µ—А–Є—В—М –њ—А–Њ–≥–љ–Њ–Ј –њ–Њ–≥–Њ–і—Л –љ–∞ —Б–∞–є—В–µ —Б–µ—А–≤–Є—Б–∞ –њ–Њ–≥–Њ–і—Л, —В–∞–Ї–Њ–≥–Њ –Ї–∞–Ї –ѓ–љ–і–µ–Ї—Б.–Я–Њ–≥–Њ–і–∞ –Є–ї–Є AccuWeather, –і–ї—П –њ–Њ–ї—Г—З–µ–љ–Є—П –∞–Ї—В—Г–∞–ї—М–љ–Њ–є –Є–љ—Д–Њ—А–Љ–∞—Ж–Є–Є –Њ –њ–Њ–≥–Њ–і–µ –≤ –Р—Б—В–∞–љ–µ.","created_at":"2026-06-18T14:36:02.124Z"},{"_id":"6a340269d9b5fcdbe6acd4b3","id":"e80dfec0-a272-436e-a941-19ed73c97384","user_message":"–Ї–∞–Ї–Њ–µ –≤—А–µ–Љ—П –≤ –∞—Б—В–∞–љ–µ","ai_response":"–Т –Р—Б—В–∞–љ–µ –≤—А–µ–Љ—П —Б–Њ–Њ—В–≤–µ—В—Б—В–≤—Г–µ—В –≤—А–µ–Љ–µ–љ–Є –≤ –Ј–Њ–љ–µ UTC+6 (–Р–ї–Љ–∞—В–Є–љ—Б–Ї–Њ–µ –≤—А–µ–Љ—П). –Х—Б–ї–Є –≤—Л —Е–Њ—В–Є—В–µ —Г–Ј–љ–∞—В—М —В–µ–Ї—Г—Й–µ–µ –≤—А–µ–Љ—П –≤ –Р—Б—В–∞–љ–µ, —П –Љ–Њ–≥—Г –њ—А–µ–і–ї–Њ–ґ–Є—В—М –≤–∞–Љ –њ—А–Њ–≤–µ—А–Є—В—М –µ–≥–Њ –љ–∞ —Б–∞–є—В–µ –Љ–Є—А–Њ–≤–Њ–≥–Њ –≤—А–µ–Љ–µ–љ–Є –Є–ї–Є –љ–∞ –≤–∞—И–µ–Љ —В–µ–ї–µ—Д–Њ–љ–µ/–Ї–Њ–Љ–њ—М—О—В–µ—А–µ.","created_at":"2026-06-18T14:36:25.763Z"},{"_id":"6a340336ccdff796e6cfee96","id":"f292a53f-d443-4576-a4ae-f971ce53ffdc","user_message":"–Ї–∞–Ї–∞—П –њ–Њ–≥–Њ–і–∞ –≤ –∞—Б—В–∞–љ–µ","ai_response":"–ѓ –љ–µ –Љ–Њ–≥—Г –њ—А–µ–і–Њ—Б—В–∞–≤–Є—В—М —В–µ–Ї—Г—Й—Г—О –њ–Њ–≥–Њ–і—Г –≤ —А–µ–ґ–Є–Љ–µ —А–µ–∞–ї—М–љ–Њ–≥–Њ –≤—А–µ–Љ–µ–љ–Є. –Ю–і–љ–∞–Ї–Њ —П –Љ–Њ–≥—Г –њ—А–µ–і–ї–Њ–ґ–Є—В—М –≤–∞–Љ –њ—А–Њ–≤–µ—А–Є—В—М –њ—А–Њ–≥–љ–Њ–Ј –њ–Њ–≥–Њ–і—Л –љ–∞ —Б–∞–є—В–µ —Б–µ—А–≤–Є—Б–∞ –њ–Њ–≥–Њ–і—Л, —В–∞–Ї–Њ–≥–Њ –Ї–∞–Ї –ѓ–љ–і–µ–Ї—Б.–Я–Њ–≥–Њ–і–∞ –Є–ї–Є AccuWeather, –і–ї—П –њ–Њ–ї—Г—З–µ–љ–Є—П –∞–Ї—В—Г–∞–ї—М–љ–Њ–є –Є–љ—Д–Њ—А–Љ–∞—Ж–Є–Є –Њ –њ–Њ–≥–Њ–і–µ –≤ –Р—Б—В–∞–љ–µ.\n\n–Э–Њ –µ—Б–ї–Є –≤—Л —Е–Њ—В–Є—В–µ, —П –Љ–Њ–≥—Г –њ—А–µ–і–ї–Њ–ґ–Є—В—М –≤–∞–Љ –љ–µ—Б–Ї–Њ–ї—М–Ї–Њ –≤–∞—А–Є–∞–љ—В–Њ–≤, –≥–і–µ –Љ–Њ–ґ–љ–Њ –љ–∞–є—В–Є –Є–љ—Д–Њ—А–Љ–∞—Ж–Є—О –Њ –њ–Њ–≥–Њ–і–µ –≤ –Р—Б—В–∞–љ–µ:\n\n* –ѓ–љ–і–µ–Ї—Б.–Я–Њ–≥–Њ–і–∞\n* AccuWeather\n* –У–Є–і—А–Њ–Љ–µ—В—Ж–µ–љ—В—А –Ъ–∞–Ј–∞—Е—Б—В–∞–љ–∞\n* –Я–Њ–≥–Њ–і–∞ –љ–∞ —Б–∞–є—В–µ –Ъ–∞–Ј–Є–љ—Д–Њ—А–Љ–∞\n\n–Я–Њ–ґ–∞–ї—Г–є—Б—В–∞, –≤—Л–±–µ—А–Є—В–µ –Њ–і–Є–љ –Є–Ј —Н—В–Є—Е –≤–∞—А–Є–∞–љ—В–Њ–≤, —З—В–Њ–±—Л –њ–Њ–ї—Г—З–Є—В—М –∞–Ї—В—Г–∞–ї—М–љ—Г—О –Є–љ—Д–Њ—А–Љ–∞—Ж–Є—О –Њ –њ–Њ–≥–Њ–і–µ –≤ –Р—Б—В–∞–љ–µ.","created_at":"2026-06-18T14:39:50.569Z"},{"_id":"6a34034eccdff796e6cfee97","id":"451592ce-d2fd-4c12-8946-5230c505089c","user_message":"–ѓ–љ–і–µ–Ї—Б.–Я–Њ–≥–Њ–і–∞","ai_response":"–ѓ–љ–і–µ–Ї—Б.–Я–Њ–≥–Њ–і–∞ - –Њ—В–ї–Є—З–љ—Л–є —А–µ—Б—Г—А—Б –і–ї—П –њ–Њ–ї—Г—З–µ–љ–Є—П –∞–Ї—В—Г–∞–ї—М–љ–Њ–є –Є–љ—Д–Њ—А–Љ–∞—Ж–Є–Є –Њ –њ–Њ–≥–Њ–і–µ. –Т—Л –Љ–Њ–ґ–µ—В–µ –њ–Њ—Б–µ—В–Є—В—М —Б–∞–є—В –ѓ–љ–і–µ–Ї—Б.–Я–Њ–≥–Њ–і–∞ –Є –≤–≤–µ—Б—В–Є \"–Р—Б—В–∞–љ–∞\" –≤ –њ–Њ–Є—Б–Ї–Њ–≤–Њ–µ –њ–Њ–ї–µ, —З—В–Њ–±—Л –њ–Њ–ї—Г—З–Є—В—М —В–µ–Ї—Г—Й—Г—О –њ–Њ–≥–Њ–і—Г –Є –њ—А–Њ–≥–љ–Њ–Ј –љ–∞ –±–ї–Є–ґ–∞–є—И–Є–µ –і–љ–Є.\n\n–Х—Б–ї–Є –≤—Л —Е–Њ—В–Є—В–µ, —П –Љ–Њ–≥—Г –њ–Њ–њ—Л—В–∞—В—М—Б—П –њ—А–µ–і–Њ—Б—В–∞–≤–Є—В—М –≤–∞–Љ –Ї—А–∞—В–Ї—Г—О –Є–љ—Д–Њ—А–Љ–∞—Ж–Є—О –Њ –њ–Њ–≥–Њ–і–µ –≤ –Р—Б—В–∞–љ–µ –љ–∞ –Њ—Б–љ–Њ–≤–µ –і–∞–љ–љ—Л—Е –ѓ–љ–і–µ–Ї—Б.–Я–Њ–≥–Њ–і–∞. –Ю–і–љ–∞–Ї–Њ, –њ–Њ–ґ–∞–ї—Г–є—Б—В–∞, –Є–Љ–µ–є—В–µ –≤ –≤–Є–і—Г, —З—В–Њ –Љ–Њ—П –Є–љ—Д–Њ—А–Љ–∞—Ж–Є—П –Љ–Њ–ґ–µ—В –±—Л—В—М –љ–µ –∞–Ї—В—Г–∞–ї—М–љ–Њ–є.","created_at":"2026-06-18T14:40:14.975Z"},{"_id":"6a3403c4ccdff796e6cfee98","id":"ae382e88-9976-417f-884c-78b34103b6b7","user_message":"–Ї–∞–Ї–∞—П –њ–Њ–≥–Њ–і–∞ –≤ –∞—Б—В–∞–љ–µ","ai_response":"–Ъ —Б–Њ–ґ–∞–ї–µ–љ–Є—О, —Г –Љ–µ–љ—П –љ–µ—В –њ—А—П–Љ–Њ–≥–Њ –і–Њ—Б—В—Г–њ–∞ –Ї –∞–Ї—В—Г–∞–ї—М–љ—Л–Љ –і–∞–љ–љ—Л–Љ –Њ –њ–Њ–≥–Њ–і–µ. –Э–Њ —П –Љ–Њ–≥—Г –њ—А–µ–і–ї–Њ–ґ–Є—В—М –≤–∞–Љ –њ—А–Њ–≤–µ—А–Є—В—М —Б–∞–є—В –ѓ–љ–і–µ–Ї—Б.–Я–Њ–≥–Њ–і–∞, —З—В–Њ–±—Л –њ–Њ–ї—Г—З–Є—В—М —В–µ–Ї—Г—Й—Г—О –Є–љ—Д–Њ—А–Љ–∞—Ж–Є—О –Њ –њ–Њ–≥–Њ–і–µ –≤ –Р—Б—В–∞–љ–µ.\n\n–Х—Б–ї–Є –≤—Л —Е–Њ—В–Є—В–µ, —П –Љ–Њ–≥—Г –њ–Њ–њ—Л—В–∞—В—М—Б—П –њ—А–µ–і–Њ—Б—В–∞–≤–Є—В—М –≤–∞–Љ –Њ–±—Й—Г—О –Є–љ—Д–Њ—А–Љ–∞—Ж–Є—О –Њ –Ї–ї–Є–Љ–∞—В–µ –Р—Б—В–∞–љ—Л. –Р—Б—В–∞–љ–∞ - –≥–Њ—А–Њ–і —Б –Ї–Њ–љ—В–Є–љ–µ–љ—В–∞–ї—М–љ—Л–Љ –Ї–ї–Є–Љ–∞—В–Њ–Љ, —Е–∞—А–∞–Ї—В–µ—А–Є–Ј—Г—О—Й–Є–Љ—Б—П —Е–Њ–ї–Њ–і–љ—Л–Љ–Є –Ј–Є–Љ–∞–Љ–Є –Є —В–µ–њ–ї—Л–Љ–Є –ї–µ—В–∞–Љ–Є. –Ч–Є–Љ–Њ–є —В–µ–Љ–њ–µ—А–∞—В—Г—А–∞ –Љ–Њ–ґ–µ—В –Њ–њ—Г—Б–Ї–∞—В—М—Б—П –і–Њ -20¬∞C, –∞ –ї–µ—В–Њ–Љ –њ–Њ–і–љ–Є–Љ–∞—В—М—Б—П –і–Њ +30¬∞C.\n\n–Я–Њ–ґ–∞–ї—Г–є—Б—В–∞, –њ–Њ—Б–µ—В–Є—В–µ —Б–∞–є—В –ѓ–љ–і–µ–Ї—Б.–Я–Њ–≥–Њ–і–∞, —З—В–Њ–±—Л –њ–Њ–ї—Г—З–Є—В—М –∞–Ї—В—Г–∞–ї—М–љ—Г—О –Є–љ—Д–Њ—А–Љ–∞—Ж–Є—О –Њ –њ–Њ–≥–Њ–і–µ –≤ –Р—Б—В–∞–љ–µ.","created_at":"2026-06-18T14:42:12.211Z"}]}
